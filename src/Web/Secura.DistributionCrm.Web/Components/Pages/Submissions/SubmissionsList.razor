@page "/submissions"
@attribute [Authorize(Policy = SecuraPolicies.CanViewSubmissions)]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject NavigationManager Nav
@using MediatR
@using Secura.DistributionCrm.Submissions.Application.DTOs
@using Secura.DistributionCrm.Submissions.Application.Queries
@using Secura.DistributionCrm.BuildingBlocks.Application.Models
@using Secura.DistributionCrm.SharedKernel.Enums

<PageTitle>Submissions — SECURA CRM</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Submissions</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="3">
            <MudSelect T="SubmissionStatus?" Label="Status" @bind-Value="_filterStatus" Clearable="true">
                @foreach (var s in Enum.GetValues<SubmissionStatus>())
                {
                    <MudSelectItem Value="(SubmissionStatus?)s">@s</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="LobType?" Label="Line of Business" @bind-Value="_filterLob" Clearable="true">
                @foreach (var l in Enum.GetValues<LobType>())
                {
                    <MudSelectItem Value="(LobType?)l">@l</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="2">
            <MudTextField @bind-Value="_filterState" Label="State" MaxLength="2" />
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-end gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadData">
                Search
            </MudButton>
            <MudButton Variant="Variant.Text" OnClick="ClearFilters">Clear</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_result != null)
{
    <MudDataGrid T="SubmissionSummaryDto" Items="_result.Items" Hover="true" Dense="true">
        <Columns>
            <PropertyColumn Property="x => x.InsuredName" Title="Insured" />
            <PropertyColumn Property="x => x.AgencyName" Title="Agency" />
            <TemplateColumn Title="LOB">
                <CellTemplate><MudText>@context.Item.Lob</MudText></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.State" Title="State" />
            <TemplateColumn Title="Status">
                <CellTemplate>
                    <MudChip T="string" Color="@GetStatusColor(context.Item.Status)" Size="Size.Small">
                        @context.Item.Status
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="SLA">
                <CellTemplate>
                    @if (context.Item.IsOverdue)
                    {
                        <MudChip T="string" Color="Color.Error" Size="Size.Small">OVERDUE</MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption">@context.Item.SlaDeadline.ToString("MM/dd HH:mm")</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ReceivedDate" Title="Received" Format="MM/dd/yyyy" />
            <TemplateColumn>
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                                   Href="@($"/submissions/{context.Item.Id}")" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>

    <MudPagination Class="mt-3" Count="_result.TotalPages" Selected="_page"
                   SelectedChanged="PageChanged" />
}

@code {
    private PagedResult<SubmissionSummaryDto>? _result;
    private bool _loading;
    private int _page = 1;
    private SubmissionStatus? _filterStatus;
    private LobType? _filterLob;
    private string? _filterState;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _result = await Mediator.Send(new GetSubmissionsQuery(
                _page, 25, _filterStatus, _filterLob, _filterState));
        }
        finally { _loading = false; }
    }

    private async Task PageChanged(int page) { _page = page; await LoadData(); }

    private void ClearFilters() { _filterStatus = null; _filterLob = null; _filterState = null; }

    private static Color GetStatusColor(SubmissionStatus s) => s switch
    {
        SubmissionStatus.Bound => Color.Success,
        SubmissionStatus.Declined => Color.Error,
        SubmissionStatus.Quoted => Color.Info,
        SubmissionStatus.Referred => Color.Warning,
        _ => Color.Default
    };
}
