<AuthorizeView>
    <Authorized>
        <MudText Typo="Typo.body2" Class="mr-2">@context.User.Identity?.Name</MudText>
        <MudIconButton Href="MicrosoftIdentity/Account/SignOut" Icon="@Icons.Material.Filled.Logout"
                       Color="Color.Inherit" Title="Sign out" />
    </Authorized>
    <NotAuthorized>
        <MudButton Href="MicrosoftIdentity/Account/SignIn" Variant="Variant.Text"
                   Color="Color.Inherit">Sign in</MudButton>
    </NotAuthorized>
</AuthorizeView>
