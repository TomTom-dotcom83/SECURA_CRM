@page "/agencies/{Id:guid}"
@attribute [Authorize(Policy = SecuraPolicies.ReadOnly)]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@using SECURA.Application.Agencies.DTOs
@using SECURA.Application.Agencies.Queries
@using SECURA.Application.Producers.DTOs
@using SECURA.Application.Producers.Queries
@using SECURA.Application.Submissions.DTOs
@using SECURA.Application.Submissions.Queries
@using MediatR

<PageTitle>@(_agency?.Name ?? "Agency") — SECURA CRM</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_agency != null)
{
    <!-- Header -->
    <MudPaper Class="pa-4 mb-4">
        <MudGrid Class="align-center">
            <MudItem xs="12" md="8">
                <MudText Typo="Typo.h5">@_agency.Name</MudText>
                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudChip T="string" Color="@GetStatusColor(_agency.Status)" Size="Size.Small">
                        @_agency.Status
                    </MudChip>
                    <MudChip T="string" Size="Size.Small">@_agency.Tier</MudChip>
                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.LocationOn">
                        @_agency.PrimaryState
                    </MudChip>
                </MudStack>
                <MudText Typo="Typo.caption" Class="mt-1">
                    @_agency.BranchCount branches · @_agency.ProducerCount producers ·
                    @_agency.ActiveLicenseCount active licenses
                </MudText>
            </MudItem>
            <MudItem xs="12" md="4" Class="d-flex justify-end gap-2">
                <AuthorizeView Policy="@SecuraPolicies.CanManageAgencies">
                    <MudButton Variant="Variant.Outlined" Href="@($"/agencies/{Id}/edit")">
                        Edit
                    </MudButton>
                </AuthorizeView>
                <MudButton Variant="Variant.Text" Href="/agencies">
                    Back
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- Tabs -->
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4"
             ActivePanelIndexChanged="OnTabChanged">

        <!-- ── Overview ─────────────────────────────────────────────────────── -->
        <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Info">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudList T="string">
                        <MudListItem Icon="@Icons.Material.Filled.Email">
                            <MudText>@(_agency.Email ?? "—")</MudText>
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.Phone">
                            <MudText>@(_agency.Phone ?? "—")</MudText>
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.Web">
                            <MudText>@(_agency.Website ?? "—")</MudText>
                        </MudListItem>
                    </MudList>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle2">Notes</MudText>
                    <MudText>@(_agency.Notes ?? "No notes recorded.")</MudText>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- ── Producers ─────────────────────────────────────────────────────── -->
        <MudTabPanel Text="Producers" Icon="@Icons.Material.Filled.People">
            @if (_producersLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_producers?.Items.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No producers assigned to this agency.</MudAlert>
            }
            else if (_producers != null)
            {
                <MudDataGrid T="ProducerSummaryDto" Items="_producers.Items" Hover="true" Dense="true"
                             SortMode="SortMode.Single">
                    <Columns>
                        <PropertyColumn Property="x => x.Npn" Title="NPN" />
                        <PropertyColumn Property="x => x.FullName" Title="Name" />
                        <TemplateColumn Title="License Status">
                            <CellTemplate>
                                <MudChip T="string" Color="@GetLicenseColor(context.Item.LicenseStatus)" Size="Size.Small">
                                    @context.Item.LicenseStatus
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.ActiveLicenseCount" Title="Active Licenses" />
                        <TemplateColumn Title="Active">
                            <CellTemplate>
                                @if (context.Item.ActiveFlag)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
                                }
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="">
                            <CellTemplate>
                                <MudButton Size="Size.Small" Variant="Variant.Text"
                                           Href="@($"/producers/{context.Item.Id}")">View</MudButton>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            }
        </MudTabPanel>

        <!-- ── Compliance ────────────────────────────────────────────────────── -->
        <MudTabPanel Text="Compliance" Icon="@Icons.Material.Filled.Shield">
            @if (_producersLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_producers?.Items.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No producers to show compliance data for.</MudAlert>
            }
            else if (_producers != null)
            {
                var expiredCount   = _producers.Items.Count(p => p.LicenseStatus == LicenseStatus.Expired);
                var suspendedCount = _producers.Items.Count(p => p.LicenseStatus == LicenseStatus.Suspended);

                @if (expiredCount > 0 || suspendedCount > 0)
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-3">
                        @if (expiredCount > 0)   { <span>@expiredCount expired license@(expiredCount   == 1 ? "" : "s"). </span> }
                        @if (suspendedCount > 0) { <span>@suspendedCount suspended license@(suspendedCount == 1 ? "" : "s").</span> }
                    </MudAlert>
                }

                <MudDataGrid T="ProducerSummaryDto" Items="_producers.Items" Hover="true" Dense="true"
                             SortMode="SortMode.Single">
                    <Columns>
                        <PropertyColumn Property="x => x.Npn" Title="NPN" />
                        <PropertyColumn Property="x => x.FullName" Title="Producer" />
                        <TemplateColumn Title="License Status">
                            <CellTemplate>
                                <MudChip T="string" Color="@GetLicenseColor(context.Item.LicenseStatus)" Size="Size.Small">
                                    @context.Item.LicenseStatus
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.ActiveLicenseCount" Title="Active Licenses" />
                        <TemplateColumn Title="Compliance">
                            <CellTemplate>
                                @{
                                    var ok = context.Item.LicenseStatus == LicenseStatus.Active
                                             && context.Item.ActiveLicenseCount > 0;
                                }
                                @if (ok)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Compliant</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Review Required</MudChip>
                                }
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            }
        </MudTabPanel>

        <!-- ── Submissions ───────────────────────────────────────────────────── -->
        <MudTabPanel Text="Submissions" Icon="@Icons.Material.Filled.Description">
            @if (_submissionsLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_submissions?.Items.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No submissions for this agency.</MudAlert>
            }
            else if (_submissions != null)
            {
                <MudDataGrid T="SubmissionSummaryDto" Items="_submissions.Items" Hover="true" Dense="true"
                             SortMode="SortMode.Single">
                    <Columns>
                        <PropertyColumn Property="x => x.InsuredName" Title="Insured" />
                        <PropertyColumn Property="x => x.Lob" Title="LOB" />
                        <PropertyColumn Property="x => x.State" Title="State" />
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <MudChip T="string" Color="@GetSubmissionColor(context.Item.Status)" Size="Size.Small">
                                    @context.Item.Status
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.ReceivedDate" Title="Received" Format="yyyy-MM-dd" />
                        <TemplateColumn Title="SLA">
                            <CellTemplate>
                                @if (context.Item.IsOverdue)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.Warning">
                                        Overdue
                                    </MudChip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2">@context.Item.SlaDeadline.ToString("yyyy-MM-dd")</MudText>
                                }
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="">
                            <CellTemplate>
                                <MudButton Size="Size.Small" Variant="Variant.Text"
                                           Href="@($"/submissions/{context.Item.Id}")">View</MudButton>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            }
        </MudTabPanel>

        <!-- ── Interactions ──────────────────────────────────────────────────── -->
        <MudTabPanel Text="Interactions" Icon="@Icons.Material.Filled.Forum">
            <MudAlert Severity="Severity.Info">Interaction timeline coming soon.</MudAlert>
        </MudTabPanel>

        <!-- ── Documents ─────────────────────────────────────────────────────── -->
        <MudTabPanel Text="Documents" Icon="@Icons.Material.Filled.Folder">
            <MudAlert Severity="Severity.Info">Document library coming soon.</MudAlert>
        </MudTabPanel>

    </MudTabs>
}
else
{
    <MudAlert Severity="Severity.Error">Agency not found.</MudAlert>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private AgencyDto?                       _agency;
    private PagedResult<ProducerSummaryDto>?  _producers;
    private PagedResult<SubmissionSummaryDto>? _submissions;
    private bool _loading;
    private bool _producersLoaded;
    private bool _submissionsLoaded;
    private bool _producersLoading;
    private bool _submissionsLoading;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _agency = await Mediator.Send(new GetAgencyByIdQuery(Id));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally { _loading = false; }
    }

    private async Task OnTabChanged(int index)
    {
        // Tab 1 = Producers, Tab 2 = Compliance (both use same producer data)
        if ((index == 1 || index == 2) && !_producersLoaded)
        {
            _producersLoading = true;
            try
            {
                _producers = await Mediator.Send(
                    new GetProducersQuery(1, 100, AgencyId: Id));
                _producersLoaded = true;
            }
            catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
            finally { _producersLoading = false; }
        }

        // Tab 3 = Submissions
        if (index == 3 && !_submissionsLoaded)
        {
            _submissionsLoading = true;
            try
            {
                _submissions = await Mediator.Send(
                    new GetSubmissionsQuery(1, 50, AgencyId: Id));
                _submissionsLoaded = true;
            }
            catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
            finally { _submissionsLoading = false; }
        }
    }

    private static Color GetStatusColor(SECURA.Domain.Enums.AgencyStatus status) => status switch
    {
        SECURA.Domain.Enums.AgencyStatus.Active => Color.Success,
        SECURA.Domain.Enums.AgencyStatus.Rejected
            or SECURA.Domain.Enums.AgencyStatus.Terminated => Color.Error,
        SECURA.Domain.Enums.AgencyStatus.Suspended => Color.Warning,
        _ => Color.Default
    };

    private static Color GetLicenseColor(LicenseStatus status) => status switch
    {
        LicenseStatus.Active    => Color.Success,
        LicenseStatus.Expired
            or LicenseStatus.Cancelled => Color.Error,
        LicenseStatus.Suspended => Color.Warning,
        _ => Color.Default
    };

    private static Color GetSubmissionColor(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Bound   => Color.Success,
        SubmissionStatus.Declined => Color.Error,
        SubmissionStatus.Quoted  => Color.Info,
        SubmissionStatus.InReview or SubmissionStatus.Referred => Color.Primary,
        _ => Color.Default
    };
}
